// Delete Vertex
void deleteVertex(int *N) {
    int v;
    printf("Enter the vertex to be deleted : ");
    scanf("%d", &v);

    if (*N == 0) {
        printf("Graph is empty.\n");
        return;
    }

    if (v < 1 || v > *N) {
        printf("Invalid vertex.\n");
        return;
    }

    // Remove outgoing edges
    GNODE temp = graph[v];
    while (temp != NULL) {
        GNODE t = temp;
        temp = temp->next;
        free(t);
    }
    graph[v] = NULL;

    // Remove incoming edges
    for (int i = 1; i <= *N; i++) {
        GNODE curr = graph[i], prev = NULL;
        while (curr != NULL) {
            if (curr->vertex == v) {
                if (prev == NULL)
                    graph[i] = curr->next;
                else
                    prev->next = curr->next;

                GNODE del = curr;
                curr = curr->next;
                free(del);
            } else {
                prev = curr;
                curr = curr->next;
            }
        }
    }

    printf("After deleting vertex the adjacency list is : \n");
    print(N);
}
